import Physicslib4.AQFT.HaagKastler.Net
import Physicslib4.AQFT.HaagKastler.QuasilocalAction
import Physicslib4.Spacetime.MinkowskiDirected
import Physicslib4.Spacetime.LorentzCausality
import Physicslib4.Analysis.CStarDenseExtend

/-!
# Towards the intertwiner on the generated subalgebra

This file begins assembling the densely-defined intertwiner used to lift the
fiberwise covariance action to the quasilocal algebra (`QuasilocalLift`). Two
ingredients are established here:

* `IsAlexandrovBasisSet.directed`: the Haag-Kastler-level restatement of
  `Spacetime.alexandrovBasis_directed` (any two basis sets lie in a common
  basis set).
* `dense_adjoin_iUnion_range_О№`: the `*`-subalgebra of `рқ”ҳ` generated by the
  union of the local images `О№_B(рқ”ҳ(B))` is dense - so it is a valid domain for
  the dense-extension lemma `exists_starAlgHom_extend_of_dense`.

The remaining step - defining the intertwiner `О№_B a вҶҰ О№_{LВ·B}(Оұ_L a)` on this
generated subalgebra and checking it is a well-defined `*`-homomorphism - will
use `StarAlgebra.adjoin_induction` together with the isotony-coherence field
`QuasilocalAlgebra.О№_inclusion` and basis directedness.
-/

namespace Physicslib4
namespace AQFT
namespace HaagKastler

open Physicslib4

/-- **Haag-Kastler directedness of the Alexandrov basis.** Any two
Alexandrov-basis sets are contained in a common Alexandrov-basis set. -/
theorem IsAlexandrovBasisSet.directed
    {BвӮҒ BвӮӮ : Set StandardMinkowskiSpacetime.Carrier}
    (hвӮҒ : IsAlexandrovBasisSet BвӮҒ) (hвӮӮ : IsAlexandrovBasisSet BвӮӮ) :
    вҲғ B, IsAlexandrovBasisSet B вҲ§ BвӮҒ вҠҶ B вҲ§ BвӮӮ вҠҶ B :=
  Spacetime.alexandrovBasis_directed hвӮҒ hвӮӮ

/-- The `*`-subalgebra of the quasilocal algebra generated by the union of all
local images is dense: it contains the (already dense) union of the images
`О№_B(рқ”ҳ(B))`. -/
theorem dense_adjoin_iUnion_range_О№ {U : LocalNet} (Q : QuasilocalAlgebra U) :
    Dense (StarAlgebra.adjoin в„Ӯ
      (вӢғ (B : Set StandardMinkowskiSpacetime.Carrier) (_ : IsAlexandrovBasisSet B),
        Set.range (Q.О№ B)) : Set Q.carrier) :=
  Q.dense_range.mono (StarAlgebra.subset_adjoin в„Ӯ _)

namespace QuasilocalAlgebra

variable {U : LocalNet} (Q : QuasilocalAlgebra U)

/-- The union of all local images `О№_B(рқ”ҳ(B))` over Alexandrov-basis sets `B`. -/
def localImages : Set Q.carrier :=
  вӢғ (B : Set StandardMinkowskiSpacetime.Carrier) (_ : IsAlexandrovBasisSet B),
    Set.range (Q.О№ B)

@[simp] theorem mem_localImages {x : Q.carrier} :
    x вҲҲ Q.localImages вҶ” вҲғ B, IsAlexandrovBasisSet B вҲ§ вҲғ a, Q.О№ B a = x := by
  simp only [localImages, Set.mem_iUnion, Set.mem_range, exists_prop]

/-- **Directedness of the local images.** Any two elements of the union of
local images are images, from a *common* basis set `C`, of elements of
`рқ”ҳ(C)` - using basis directedness and the isotony-coherence `О№_inclusion`. -/
theorem exists_common_image {x y : Q.carrier}
    (hx : x вҲҲ Q.localImages) (hy : y вҲҲ Q.localImages) :
    вҲғ C, IsAlexandrovBasisSet C вҲ§ вҲғ a b : U.algebra C,
      Q.О№ C a = x вҲ§ Q.О№ C b = y := by
  rw [mem_localImages] at hx hy
  obtain вҹЁB, hB, a, rflвҹ© := hx
  obtain вҹЁB', hB', a', rflвҹ© := hy
  obtain вҹЁC, hC, hBC, hB'Cвҹ© := IsAlexandrovBasisSet.directed hB hB'
  exact вҹЁC, hC, Q.inclusion hB hC hBC a, Q.inclusion hB' hC hB'C a',
    Q.О№_inclusion hB hC hBC a, Q.О№_inclusion hB' hC hB'C a'вҹ©

/-- **The union of local images is a `*`-subalgebra of the quasilocal algebra.**
Closure under multiplication and addition uses directedness (`exists_common_image`)
to route both arguments through a single embedding `О№_C`; closure under `star`,
`1`, `0`, and scalars is pointwise. -/
def localStarSubalgebra : StarSubalgebra в„Ӯ Q.carrier where
  carrier := Q.localImages
  mul_mem' := by
    intro x y hx hy
    obtain вҹЁC, hC, a, b, rfl, rflвҹ© := Q.exists_common_image hx hy
    rw [mem_localImages]
    exact вҹЁC, hC, a * b, by rw [map_mul]вҹ©
  add_mem' := by
    intro x y hx hy
    obtain вҹЁC, hC, a, b, rfl, rflвҹ© := Q.exists_common_image hx hy
    rw [mem_localImages]
    exact вҹЁC, hC, a + b, by rw [map_add]вҹ©
  one_mem' := by
    rw [mem_localImages]
    exact вҹЁtrivialBasisSet, isAlexandrovBasisSet_trivialBasisSet, 1, by rw [map_one]вҹ©
  zero_mem' := by
    rw [mem_localImages]
    exact вҹЁtrivialBasisSet, isAlexandrovBasisSet_trivialBasisSet, 0, by rw [map_zero]вҹ©
  algebraMap_mem' := by
    intro r
    rw [mem_localImages]
    exact вҹЁtrivialBasisSet, isAlexandrovBasisSet_trivialBasisSet,
      algebraMap в„Ӯ _ r, AlgHomClass.commutes (Q.О№ trivialBasisSet) rвҹ©
  star_mem' := by
    intro x hx
    rw [mem_localImages] at hx вҠў
    obtain вҹЁB, hB, a, rflвҹ© := hx
    exact вҹЁB, hB, star a, by rw [map_star]вҹ©

@[simp] theorem coe_localStarSubalgebra :
    (Q.localStarSubalgebra : Set Q.carrier) = Q.localImages := rfl

/-- The local `*`-subalgebra is dense in the quasilocal algebra. -/
theorem dense_localStarSubalgebra :
    Dense (Q.localStarSubalgebra : Set Q.carrier) := by
  rw [coe_localStarSubalgebra]
  exact Q.dense_range

/-- **Naturality of the embeddings under set equality.** If `BвӮҒ = BвӮӮ` then the
embedding of `a` and of its transport agree in `рқ”ҳ`. Used to reconcile the
cross-fiber casts coming from `covEquiv_one` / `covEquiv_mul`. -/
theorem О№_cast {BвӮҒ BвӮӮ : Set StandardMinkowskiSpacetime.Carrier} (h : BвӮҒ = BвӮӮ)
    (a : U.algebra BвӮҒ) :
    Q.О№ BвӮӮ ((congrArg U.algebra h).mp a) = Q.О№ BвӮҒ a := by
  subst h; rfl

end QuasilocalAlgebra

open scoped Pointwise

/-- **Covariance-compatible embeddings.** A quasilocal algebra `Q` of the net
`N` is *covariant-compatible* for a Lorentz transformation `L` if its local
embeddings intertwine the covariance action with the chosen isotony inclusions:
`О№_{LВ·B}(Оұ_L a) = О№_{LВ·C}(Оұ_L (incl_{B,C} a))` for `B вҠҶ C`. This is the
honest content carried by the embeddings of a genuinely covariant `рқ”ҳ`. -/
def IsCovariantQuasilocal (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) : Prop :=
  вҲҖ вҰғB C : Set StandardMinkowskiSpacetime.CarrierвҰ„
    (hB : IsAlexandrovBasisSet B) (hC : IsAlexandrovBasisSet C) (h : B вҠҶ C)
    (a : N.U.algebra B),
      Q.О№ (L вҖў B) (N.covEquiv L B a)
        = Q.О№ (L вҖў C) (N.covEquiv L C (Q.inclusion hB hC h a))

/-- **Well-definedness of the intertwiner.** If two local elements `О№_B a` and
`О№_{B'} a'` agree in `рқ”ҳ`, then their intended images
`О№_{LВ·B}(Оұ_L a)` and `О№_{LВ·B'}(Оұ_L a')` agree. The proof routes both through a
common basis set `C` (directedness), uses `О№_inclusion` + injectivity to
identify the inclusions, and `hcompat` to push through the action. -/
theorem О№_covEquiv_congr (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    вҰғB B' : Set StandardMinkowskiSpacetime.CarrierвҰ„
    (hB : IsAlexandrovBasisSet B) (hB' : IsAlexandrovBasisSet B')
    (a : N.U.algebra B) (a' : N.U.algebra B') (heq : Q.О№ B a = Q.О№ B' a') :
    Q.О№ (L вҖў B) (N.covEquiv L B a) = Q.О№ (L вҖў B') (N.covEquiv L B' a') := by
  obtain вҹЁC, hC, hBC, hB'Cвҹ© := IsAlexandrovBasisSet.directed hB hB'
  have hinj : Q.inclusion hB hC hBC a = Q.inclusion hB' hC hB'C a' := by
    apply Q.О№_injective hC
    rw [Q.О№_inclusion hB hC hBC a, Q.О№_inclusion hB' hC hB'C a']
    exact heq
  calc Q.О№ (L вҖў B) (N.covEquiv L B a)
      = Q.О№ (L вҖў C) (N.covEquiv L C (Q.inclusion hB hC hBC a)) := hcompat hB hC hBC a
    _ = Q.О№ (L вҖў C) (N.covEquiv L C (Q.inclusion hB' hC hB'C a')) := by rw [hinj]
    _ = Q.О№ (L вҖў B') (N.covEquiv L B' a') := (hcompat hB' hC hB'C a').symm

open Classical in
/-- The **intertwiner** on the quasilocal algebra: on a local element `О№_B a`
it returns `О№_{LВ·B}(Оұ_L a)` (and `0` off the local images). Its characterising
equation is `intertwiner_О№`, valid once `Q` is covariance-compatible. -/
noncomputable def intertwiner (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (x : Q.carrier) : Q.carrier :=
  if h : вҲғ B, IsAlexandrovBasisSet B вҲ§ вҲғ a : N.U.algebra B, Q.О№ B a = x then
    Q.О№ (L вҖў h.choose) (N.covEquiv L h.choose h.choose_spec.2.choose)
  else 0

/-- **Defining equation of the intertwiner.** On `О№_B a` it returns
`О№_{LВ·B}(Оұ_L a)`, well-definedly. -/
theorem intertwiner_О№ (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    {B : Set StandardMinkowskiSpacetime.Carrier} (hB : IsAlexandrovBasisSet B)
    (a : N.U.algebra B) :
    intertwiner N Q L (Q.О№ B a) = Q.О№ (L вҖў B) (N.covEquiv L B a) := by
  have hвӮҖ : вҲғ B', IsAlexandrovBasisSet B' вҲ§ вҲғ a' : N.U.algebra B', Q.О№ B' a' = Q.О№ B a :=
    вҹЁB, hB, a, rflвҹ©
  unfold intertwiner
  rw [dif_pos hвӮҖ]
  exact О№_covEquiv_congr N Q L hcompat hвӮҖ.choose_spec.1 hB hвӮҖ.choose_spec.2.choose a
    hвӮҖ.choose_spec.2.choose_spec

/-- **Additivity of the intertwiner.** On the local images it preserves
addition - both arguments are routed through a common basis algebra `О№_C`. -/
theorem intertwiner_add (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    {x y : Q.carrier} (hx : x вҲҲ Q.localImages) (hy : y вҲҲ Q.localImages) :
    intertwiner N Q L (x + y) = intertwiner N Q L x + intertwiner N Q L y := by
  obtain вҹЁC, hC, a, b, rfl, rflвҹ© := Q.exists_common_image hx hy
  rw [вҶҗ map_add (Q.О№ C), intertwiner_О№ N Q L hcompat hC (a + b),
    intertwiner_О№ N Q L hcompat hC a, intertwiner_О№ N Q L hcompat hC b,
    map_add (N.covEquiv L C), map_add (Q.О№ (L вҖў C))]

/-- **Multiplicativity of the intertwiner.** On the local images it preserves
multiplication - both arguments are routed through a common basis algebra. -/
theorem intertwiner_mul (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    {x y : Q.carrier} (hx : x вҲҲ Q.localImages) (hy : y вҲҲ Q.localImages) :
    intertwiner N Q L (x * y) = intertwiner N Q L x * intertwiner N Q L y := by
  obtain вҹЁC, hC, a, b, rfl, rflвҹ© := Q.exists_common_image hx hy
  rw [вҶҗ map_mul (Q.О№ C), intertwiner_О№ N Q L hcompat hC (a * b),
    intertwiner_О№ N Q L hcompat hC a, intertwiner_О№ N Q L hcompat hC b,
    map_mul (N.covEquiv L C), map_mul (Q.О№ (L вҖў C))]

/-- The intertwiner preserves `0`. -/
theorem intertwiner_zero (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L) :
    intertwiner N Q L 0 = 0 := by
  have h : intertwiner N Q L (Q.О№ trivialBasisSet (0 : N.U.algebra trivialBasisSet)) = 0 := by
    rw [intertwiner_О№ N Q L hcompat isAlexandrovBasisSet_trivialBasisSet 0, map_zero, map_zero]
  simpa using h

/-- The intertwiner preserves `1`. -/
theorem intertwiner_one (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L) :
    intertwiner N Q L 1 = 1 := by
  have h : intertwiner N Q L (Q.О№ trivialBasisSet (1 : N.U.algebra trivialBasisSet)) = 1 := by
    rw [intertwiner_О№ N Q L hcompat isAlexandrovBasisSet_trivialBasisSet 1, map_one, map_one]
  simpa using h

/-- The intertwiner preserves `star` on the local images. -/
theorem intertwiner_star (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    {x : Q.carrier} (hx : x вҲҲ Q.localImages) :
    intertwiner N Q L (star x) = star (intertwiner N Q L x) := by
  rw [Q.mem_localImages] at hx
  obtain вҹЁB, hB, a, rflвҹ© := hx
  rw [вҶҗ map_star (Q.О№ B), intertwiner_О№ N Q L hcompat hB (star a),
    intertwiner_О№ N Q L hcompat hB a, map_star (N.covEquiv L B), map_star (Q.О№ (L вҖў B))]

/-- The intertwiner is `в„Ӯ`-linear on the local images. -/
theorem intertwiner_smul (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    (c : в„Ӯ) {x : Q.carrier} (hx : x вҲҲ Q.localImages) :
    intertwiner N Q L (c вҖў x) = c вҖў intertwiner N Q L x := by
  rw [Q.mem_localImages] at hx
  obtain вҹЁB, hB, a, rflвҹ© := hx
  rw [вҶҗ map_smul (Q.О№ B) c a, intertwiner_О№ N Q L hcompat hB (c вҖў a),
    intertwiner_О№ N Q L hcompat hB a, map_smul (N.covEquiv L B), map_smul (Q.О№ (L вҖў B))]

/-- **The intertwiner as a `*`-homomorphism on the local subalgebra.** Bundles
the homomorphism laws of `intertwiner` into a `StarAlgHom` from the dense local
`*`-subalgebra of `рқ”ҳ` into `рқ”ҳ`. -/
noncomputable def intertwinerHom (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L) :
    Q.localStarSubalgebra вҶ’вӢҶвӮҗ[в„Ӯ] Q.carrier where
  toFun s := intertwiner N Q L (s : Q.carrier)
  map_one' := by
    change intertwiner N Q L ((1 : Q.localStarSubalgebra) : Q.carrier) = 1
    rw [OneMemClass.coe_one]; exact intertwiner_one N Q L hcompat
  map_mul' s t := by
    change intertwiner N Q L ((s * t : Q.localStarSubalgebra) : Q.carrier)
      = intertwiner N Q L (s : Q.carrier) * intertwiner N Q L (t : Q.carrier)
    rw [MulMemClass.coe_mul]; exact intertwiner_mul N Q L hcompat s.2 t.2
  map_zero' := by
    change intertwiner N Q L ((0 : Q.localStarSubalgebra) : Q.carrier) = 0
    rw [ZeroMemClass.coe_zero]; exact intertwiner_zero N Q L hcompat
  map_add' s t := by
    change intertwiner N Q L ((s + t : Q.localStarSubalgebra) : Q.carrier)
      = intertwiner N Q L (s : Q.carrier) + intertwiner N Q L (t : Q.carrier)
    rw [AddMemClass.coe_add]; exact intertwiner_add N Q L hcompat s.2 t.2
  commutes' r := by
    change intertwiner N Q L ((algebraMap в„Ӯ Q.localStarSubalgebra r : Q.carrier))
      = algebraMap в„Ӯ Q.carrier r
    have hcoe : ((algebraMap в„Ӯ Q.localStarSubalgebra r : Q.carrier))
        = algebraMap в„Ӯ Q.carrier r :=
      AlgHomClass.commutes (StarSubalgebra.subtype Q.localStarSubalgebra) r
    rw [hcoe, Algebra.algebraMap_eq_smul_one,
      intertwiner_smul N Q L hcompat r (one_mem Q.localStarSubalgebra),
      intertwiner_one N Q L hcompat]
  map_star' s := by
    rw [StarMemClass.coe_star]; exact intertwiner_star N Q L hcompat s.2

@[simp] theorem intertwinerHom_apply (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    (s : Q.localStarSubalgebra) :
    intertwinerHom N Q L hcompat s = intertwiner N Q L (s : Q.carrier) := rfl

/-- **The intertwiner is norm-preserving on the local images.** It maps
`О№_B a вҶҰ О№_{LВ·B}(Оұ_L a)`; both embeddings are isometric (`norm_О№`, using that
`LВ·B` is again a basis set) and `Оұ_L` is isometric (`norm_covEquiv`). -/
theorem intertwiner_norm (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L)
    {x : Q.carrier} (hx : x вҲҲ Q.localImages) :
    вҖ–intertwiner N Q L xвҖ– = вҖ–xвҖ– := by
  rw [Q.mem_localImages] at hx
  obtain вҹЁB, hB, a, rflвҹ© := hx
  rw [intertwiner_О№ N Q L hcompat hB a, Q.norm_О№ (isAlexandrovBasisSet_smul L hB),
    N.norm_covEquiv, Q.norm_О№ hB]

/-- **The bundled intertwiner is an isometry** on the local `*`-subalgebra. -/
theorem intertwinerHom_isometry (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L) :
    Isometry (intertwinerHom N Q L hcompat) := by
  refine Isometry.of_dist_eq (fun x y => ?_)
  rw [Subtype.dist_eq, dist_eq_norm, dist_eq_norm,
    вҶҗ map_sub (intertwinerHom N Q L hcompat), intertwinerHom_apply,
    AddSubgroupClass.coe_sub]
  exact intertwiner_norm N Q L hcompat (sub_mem x.2 y.2)

/-- **Existence of the extended intertwiner.** The norm-preserving (hence
uniformly continuous) `*`-homomorphism on the dense local `*`-subalgebra extends
to a `*`-homomorphism `F : рқ”ҳ вҶ’вӢҶвӮҗ[в„Ӯ] рқ”ҳ` agreeing with the intertwiner on the
local images. -/
theorem exists_intertwiner_extend (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U)
    (L : InhomogeneousLorentzGroup) (hcompat : IsCovariantQuasilocal N Q L) :
    вҲғ F : Q.carrier вҶ’вӢҶвӮҗ[в„Ӯ] Q.carrier, Continuous F вҲ§
      вҲҖ s : Q.localStarSubalgebra, F (s : Q.carrier) = intertwiner N Q L (s : Q.carrier) := by
  obtain вҹЁF, hFc, hFвҹ© := exists_starAlgHom_extend_of_dense Q.localStarSubalgebra
    Q.dense_localStarSubalgebra (intertwinerHom N Q L hcompat)
    (intertwinerHom_isometry N Q L hcompat).uniformContinuous
  exact вҹЁF, hFc, hFвҹ©

/-- A quasilocal algebra is *covariant* if its embeddings are covariance-
compatible for **every** Lorentz transformation (so the lift exists for all
`L`). -/
def IsCovariant (N : HaagKastlerNet) (Q : QuasilocalAlgebra N.U) : Prop :=
  вҲҖ L : InhomogeneousLorentzGroup, IsCovariantQuasilocal N Q L

variable {N : HaagKastlerNet} {Q : QuasilocalAlgebra N.U}

/-- The chosen extended intertwiner `ОҰ_L : рқ”ҳ вҶ’вӢҶвӮҗ[в„Ӯ] рқ”ҳ` for a covariant
quasilocal algebra. -/
noncomputable def extendHom (hcov : IsCovariant N Q)
    (L : InhomogeneousLorentzGroup) : Q.carrier вҶ’вӢҶвӮҗ[в„Ӯ] Q.carrier :=
  (exists_intertwiner_extend N Q L (hcov L)).choose

theorem extendHom_continuous (hcov : IsCovariant N Q)
    (L : InhomogeneousLorentzGroup) : Continuous (extendHom hcov L) :=
  (exists_intertwiner_extend N Q L (hcov L)).choose_spec.1

/-- `ОҰ_L` implements the fiberwise action on the generators:
`ОҰ_L (О№_B a) = О№_{LВ·B}(Оұ_L a)`. -/
theorem extendHom_О№ (hcov : IsCovariant N Q) (L : InhomogeneousLorentzGroup)
    {B : Set StandardMinkowskiSpacetime.Carrier} (hB : IsAlexandrovBasisSet B)
    (a : N.U.algebra B) :
    extendHom hcov L (Q.О№ B a) = Q.О№ (L вҖў B) (N.covEquiv L B a) := by
  have hmem : Q.О№ B a вҲҲ Q.localStarSubalgebra := (Q.mem_localImages).mpr вҹЁB, hB, a, rflвҹ©
  have h := (exists_intertwiner_extend N Q L (hcov L)).choose_spec.2 вҹЁQ.О№ B a, hmemвҹ©
  rw [intertwiner_О№ N Q L (hcov L) hB a] at h
  exact h

/-- Two `*`-homomorphisms of `рқ”ҳ` that are continuous and agree on the local
images are equal (the images are dense). -/
theorem starAlgHom_ext_localImages {f g : Q.carrier вҶ’вӢҶвӮҗ[в„Ӯ] Q.carrier}
    (hf : Continuous f) (hg : Continuous g)
    (h : вҲҖ вҰғB : Set StandardMinkowskiSpacetime.CarrierвҰ„, IsAlexandrovBasisSet B вҶ’
      вҲҖ a : N.U.algebra B, f (Q.О№ B a) = g (Q.О№ B a)) :
    f = g := by
  apply DFunLike.coe_injective
  apply Continuous.ext_on Q.dense_range hf hg
  intro x hx
  simp only [Set.mem_iUnion, Set.mem_range] at hx
  obtain вҹЁB, hB, a, rflвҹ© := hx
  exact h hB a

/-- **`ОҰ` is multiplicative in the group element:** `ОҰ_{L'В·L} = ОҰ_{L'} вҲҳ ОҰ_L`. -/
theorem extendHom_comp (hcov : IsCovariant N Q)
    (L L' : InhomogeneousLorentzGroup) :
    extendHom hcov (L' * L) = (extendHom hcov L').comp (extendHom hcov L) := by
  refine starAlgHom_ext_localImages (extendHom_continuous hcov (L' * L))
    ((extendHom_continuous hcov L').comp (extendHom_continuous hcov L)) ?_
  intro B hB a
  rw [StarAlgHom.comp_apply, extendHom_О№ hcov L hB a,
    extendHom_О№ hcov L' (isAlexandrovBasisSet_smul L hB) (N.covEquiv L B a),
    extendHom_О№ hcov (L' * L) hB a, N.covEquiv_mul L L' B a]
  exact Q.О№_cast (mul_smul L' L B).symm _

/-- **`ОҰ_1 = id`.** -/
theorem extendHom_one (hcov : IsCovariant N Q) :
    extendHom hcov 1 = StarAlgHom.id в„Ӯ Q.carrier := by
  refine starAlgHom_ext_localImages (extendHom_continuous hcov 1) continuous_id ?_
  intro B hB a
  rw [extendHom_О№ hcov 1 hB a, N.covEquiv_one B a]
  exact Q.О№_cast (one_smul InhomogeneousLorentzGroup B).symm a

theorem extendHom_comp_inv (hcov : IsCovariant N Q) (L : InhomogeneousLorentzGroup) :
    (extendHom hcov L).comp (extendHom hcov LвҒ»В№) = StarAlgHom.id в„Ӯ Q.carrier := by
  rw [вҶҗ extendHom_comp hcov LвҒ»В№ L, mul_inv_cancel, extendHom_one]

theorem extendHom_inv_comp (hcov : IsCovariant N Q) (L : InhomogeneousLorentzGroup) :
    (extendHom hcov LвҒ»В№).comp (extendHom hcov L) = StarAlgHom.id в„Ӯ Q.carrier := by
  rw [вҶҗ extendHom_comp hcov L LвҒ»В№, inv_mul_cancel, extendHom_one]

/-- **Existence of the quasilocal lift.** For a covariance-compatible quasilocal
algebra, the fiberwise Lorentz action lifts to a `*`-automorphism of `рқ”ҳ`,
inhabiting `QuasilocalLift`. -/
noncomputable def quasilocalLift (hcov : IsCovariant N Q)
    (L : InhomogeneousLorentzGroup) : N.QuasilocalLift Q L where
  ОІ := StarAlgEquiv.ofStarAlgHom (extendHom hcov L) (extendHom hcov LвҒ»В№)
        (fun x => DFunLike.congr_fun (extendHom_inv_comp hcov L) x)
        (fun x => DFunLike.congr_fun (extendHom_comp_inv hcov L) x)
  intertwines := by
    intro B hB a
    rw [StarAlgEquiv.ofStarAlgHom_apply]
    exact extendHom_О№ hcov L hB a

/-- The quasilocal lift exists for every Lorentz transformation. -/
theorem nonempty_quasilocalLift (hcov : IsCovariant N Q)
    (L : InhomogeneousLorentzGroup) : Nonempty (N.QuasilocalLift Q L) :=
  вҹЁquasilocalLift hcov Lвҹ©

/-- **The trivial quasilocal algebra is covariance-compatible.** Every local
algebra is `в„Ӯ`, every `в„Ӯ`-algebra `*`-automorphism of `в„Ӯ` is the identity, and
the embeddings/inclusions are the identity, so the compatibility holds. -/
theorem isCovariant_trivial :
    IsCovariant trivialHaagKastlerNet trivialQuasilocalAlgebra := by
  have key : вҲҖ (f : в„Ӯ вүғвӢҶвӮҗ[в„Ӯ] в„Ӯ) (z : в„Ӯ), f z = z := fun f z => by
    simpa using AlgHomClass.commutes f z
  intro L B C hB hC h a
  change trivialHaagKastlerNet.covEquiv L B a
      = trivialHaagKastlerNet.covEquiv L C (trivialQuasilocalAlgebra.inclusion hB hC h a)
  exact (key (trivialHaagKastlerNet.covEquiv L B) a).trans
    (key (trivialHaagKastlerNet.covEquiv L C)
      (trivialQuasilocalAlgebra.inclusion hB hC h a)).symm

/-- **The quasilocal lift exists unconditionally for the trivial net.** -/
noncomputable def trivialQuasilocalLift (L : InhomogeneousLorentzGroup) :
    trivialHaagKastlerNet.QuasilocalLift trivialQuasilocalAlgebra L :=
  quasilocalLift isCovariant_trivial L

theorem nonempty_trivialQuasilocalLift (L : InhomogeneousLorentzGroup) :
    Nonempty (trivialHaagKastlerNet.QuasilocalLift trivialQuasilocalAlgebra L) :=
  вҹЁtrivialQuasilocalLift Lвҹ©

/-- A **covariant quasilocal algebra**: a Haag-Kastler net together with a
quasilocal algebra whose embeddings are covariance-compatible for every Lorentz
transformation. On such data the Lorentz action lifts to a `*`-automorphism of
the quasilocal algebra for every `L`. -/
structure CovariantQuasilocalAlgebra where
  /-- The underlying Haag-Kastler net. -/
  net : HaagKastlerNet
  /-- A quasilocal algebra of the net. -/
  quasilocal : QuasilocalAlgebra net.U
  /-- Covariance-compatibility of the embeddings, for every Lorentz
  transformation. -/
  covariant : IsCovariant net quasilocal

namespace CovariantQuasilocalAlgebra

/-- The lift of the Lorentz action of `L` to a `*`-automorphism of the
quasilocal algebra, packaged as a `QuasilocalLift`. -/
noncomputable def lift (C : CovariantQuasilocalAlgebra)
    (L : InhomogeneousLorentzGroup) : C.net.QuasilocalLift C.quasilocal L :=
  quasilocalLift C.covariant L

/-- The covariance `*`-automorphism `ОІ_L` of the quasilocal algebra. -/
noncomputable def action (C : CovariantQuasilocalAlgebra)
    (L : InhomogeneousLorentzGroup) : C.quasilocal.carrier вүғвӢҶвӮҗ[в„Ӯ] C.quasilocal.carrier :=
  (C.lift L).ОІ

/-- The action implements the fiberwise covariance on the local images:
`ОІ_L (О№_B a) = О№_{LВ·B}(Оұ_L a)`. -/
theorem action_О№ (C : CovariantQuasilocalAlgebra) (L : InhomogeneousLorentzGroup)
    {B : Set StandardMinkowskiSpacetime.Carrier} (hB : IsAlexandrovBasisSet B)
    (a : C.net.U.algebra B) :
    C.action L (C.quasilocal.О№ B a)
      = C.quasilocal.О№ (L вҖў B) (C.net.covEquiv L B a) :=
  (C.lift L).intertwines hB a

/-- The action agrees with the underlying extended `*`-homomorphism. -/
theorem action_apply (C : CovariantQuasilocalAlgebra)
    (L : InhomogeneousLorentzGroup) (x : C.quasilocal.carrier) :
    C.action L x = extendHom C.covariant L x :=
  StarAlgEquiv.ofStarAlgHom_apply _ _ _ _ x

/-- **The action is trivial at the identity:** `ОІ_1 = id`. -/
theorem action_one_apply (C : CovariantQuasilocalAlgebra)
    (x : C.quasilocal.carrier) : C.action 1 x = x := by
  rw [action_apply, DFunLike.congr_fun (extendHom_one C.covariant) x]
  rfl

/-- **The action is multiplicative in the group element:**
`ОІ_{L'В·L} = ОІ_{L'} вҲҳ ОІ_L`. -/
theorem action_mul_apply (C : CovariantQuasilocalAlgebra)
    (L L' : InhomogeneousLorentzGroup) (x : C.quasilocal.carrier) :
    C.action (L' * L) x = C.action L' (C.action L x) := by
  rw [action_apply, action_apply, action_apply,
    DFunLike.congr_fun (extendHom_comp C.covariant L L') x]
  rfl

/-- The covariance action sends the identity to the identity automorphism. -/
theorem action_one (C : CovariantQuasilocalAlgebra) :
    C.action 1 = StarAlgEquiv.refl := by
  ext x; rw [action_one_apply]; rfl

/-- The covariance action is multiplicative: `ОІ_{L'В·L} = ОІ_L` followed by
`ОІ_{L'}`. -/
theorem action_mul (C : CovariantQuasilocalAlgebra)
    (L L' : InhomogeneousLorentzGroup) :
    C.action (L' * L) = (C.action L).trans (C.action L') := by
  ext x; rw [action_mul_apply]; rfl

/-- A state `Пү` on the quasilocal algebra is *(PoincarГ©-)invariant* if it is a
fixed point of the dual covariance action: `Пү(ОІ_L a) = Пү(a)` for every Lorentz
transformation `L` and every observable `a`. This is the invariance part of the
vacuum conditions; the spectrum condition is imposed separately. -/
def IsInvariantState (C : CovariantQuasilocalAlgebra)
    (Пү : Physicslib4.GNS.State C.quasilocal.carrier) : Prop :=
  вҲҖ (L : InhomogeneousLorentzGroup) (a : C.quasilocal.carrier),
    Пү (C.action L a) = Пү a

/-- **Invariance of the GNS inner product.** For an invariant state, the
sesquilinear form `(a, b) вҶҰ Пү(a^* b)` - which is the GNS inner product of the
cyclic vectors `ПҖ(a)О©`, `ПҖ(b)О©` - is preserved by the action. This is the
algebraic input that makes the implementing operator on the GNS space an
isometry, hence (Step 2) a unitary. -/
theorem IsInvariantState.inner_invariant (C : CovariantQuasilocalAlgebra)
    {Пү : Physicslib4.GNS.State C.quasilocal.carrier} (hПү : C.IsInvariantState Пү)
    (L : InhomogeneousLorentzGroup) (a b : C.quasilocal.carrier) :
    Пү (star (C.action L a) * C.action L b) = Пү (star a * b) := by
  rw [вҶҗ map_star (C.action L) a, вҶҗ map_mul (C.action L)]
  exact hПү L (star a * b)

open scoped InnerProductSpace in
/-- **Step 2: GNS unitary implementation of an invariant state.** For an
invariant state `Пү`, the fiberwise covariance action is implemented on the GNS
Hilbert space by a family of unitaries `U L` with `U L (ПҖ a О©) = ПҖ (ОІ_L a) О©` and
`U L О© = О©`. The unitaries are the dense-extension of the isometry
`ПҖ a О© вҶҰ ПҖ (ОІ_L a) О©` (isometric by `inner_invariant`), via
`LinearEquiv.extendOfIsometry`. -/
theorem IsInvariantState.exists_gns_unitary (C : CovariantQuasilocalAlgebra)
    {Пү : Physicslib4.GNS.State C.quasilocal.carrier} (hПү : C.IsInvariantState Пү) :
    вҲғ (H : Type) (_ : NormedAddCommGroup H) (_ : InnerProductSpace в„Ӯ H)
      (_ : CompleteSpace H) (ПҖ : C.quasilocal.carrier вҶ’вӢҶвӮҗ[в„Ӯ] (H вҶ’L[в„Ӯ] H)) (О© : H)
      (U : InhomogeneousLorentzGroup вҶ’ (H вүғвӮ—бөў[в„Ӯ] H)),
        (вҲҖ a : C.quasilocal.carrier, (Пү a : в„Ӯ) = вҹӘО©, ПҖ a О©вҹ«_в„Ӯ) вҲ§
        (вҲҖ (L : InhomogeneousLorentzGroup) (a : C.quasilocal.carrier),
          U L (ПҖ a О©) = ПҖ (C.action L a) О©) вҲ§
        (вҲҖ L : InhomogeneousLorentzGroup, U L О© = О©) := by
  obtain вҹЁH, _, _, _, ПҖ, О©, hcyc, hrepro, _вҹ© := Physicslib4.GNS.gns_construction Пү
  let cyc : C.quasilocal.carrier вҶ’вӮ—[в„Ӯ] H :=
    { toFun := fun a => ПҖ a О©
      map_add' := fun a b => by rw [map_add, ContinuousLinearMap.add_apply]
      map_smul' := fun c a => by rw [map_smul, ContinuousLinearMap.smul_apply]; rfl }
  have hcycdense : DenseRange (cyc : C.quasilocal.carrier вҶ’ H) := hcyc
  have q : вҲҖ x, (Пү (star x * x) : в„Ӯ) = вҹӘПҖ x О©, ПҖ x О©вҹ«_в„Ӯ := by
    intro x
    rw [hrepro (star x * x), map_mul, map_star, ContinuousLinearMap.mul_apply,
      ContinuousLinearMap.star_eq_adjoint, ContinuousLinearMap.adjoint_inner_right]
  have hnorm : вҲҖ (L : InhomogeneousLorentzGroup) (a : C.quasilocal.carrier),
      вҖ–cyc ((C.action L).toAlgEquiv.toLinearEquiv a)вҖ– = вҖ–cyc aвҖ– := by
    intro L a
    change вҖ–ПҖ (C.action L a) О©вҖ– = вҖ–ПҖ a О©вҖ–
    have key : вҹӘПҖ (C.action L a) О©, ПҖ (C.action L a) О©вҹ«_в„Ӯ = вҹӘПҖ a О©, ПҖ a О©вҹ«_в„Ӯ := by
      rw [вҶҗ q (C.action L a), вҶҗ q a]; exact IsInvariantState.inner_invariant C hПү L a a
    have h2 : вҖ–ПҖ (C.action L a) О©вҖ– ^ 2 = вҖ–ПҖ a О©вҖ– ^ 2 := by
      rw [вҶҗ inner_self_eq_norm_sq (рқ•ң := в„Ӯ), вҶҗ inner_self_eq_norm_sq (рқ•ң := в„Ӯ)]
      exact congrArg RCLike.re key
    rw [вҶҗ Real.sqrt_sq (norm_nonneg (ПҖ (C.action L a) О©)),
      вҶҗ Real.sqrt_sq (norm_nonneg (ПҖ a О©)), h2]
  let U : InhomogeneousLorentzGroup вҶ’ (H вүғвӮ—бөў[в„Ӯ] H) := fun L =>
    (C.action L).toAlgEquiv.toLinearEquiv.extendOfIsometry cyc cyc hcycdense hcycdense (hnorm L)
  refine вҹЁH, inferInstance, inferInstance, inferInstance, ПҖ, О©, U, hrepro, ?_, ?_вҹ©
  В· intro L a
    exact (C.action L).toAlgEquiv.toLinearEquiv.extendOfIsometry_eq cyc cyc hcycdense hcycdense
      (hnorm L) a
  В· intro L
    have hО© : cyc (1 : C.quasilocal.carrier) = О© := by
      change ПҖ 1 О© = О©
      rw [map_one, ContinuousLinearMap.one_apply]
    have hone : cyc ((C.action L).toAlgEquiv.toLinearEquiv (1 : C.quasilocal.carrier)) = О© := by
      change ПҖ (C.action L 1) О© = О©
      rw [map_one (C.action L)]
      change ПҖ 1 О© = О©
      rw [map_one, ContinuousLinearMap.one_apply]
    calc U L О© = U L (cyc 1) := by rw [hО©]
      _ = cyc ((C.action L).toAlgEquiv.toLinearEquiv 1) :=
          (C.action L).toAlgEquiv.toLinearEquiv.extendOfIsometry_eq cyc cyc hcycdense hcycdense
            (hnorm L) 1
      _ = О© := hone

end CovariantQuasilocalAlgebra

/-- The trivial net with its trivial quasilocal algebra is a covariant quasilocal
algebra, so the structure is inhabited. -/
noncomputable def trivialCovariantQuasilocalAlgebra : CovariantQuasilocalAlgebra where
  net := trivialHaagKastlerNet
  quasilocal := trivialQuasilocalAlgebra
  covariant := isCovariant_trivial

theorem nonempty_covariantQuasilocalAlgebra : Nonempty CovariantQuasilocalAlgebra :=
  вҹЁtrivialCovariantQuasilocalAlgebraвҹ©


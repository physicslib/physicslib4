/-!
# Minkowski spacetime and the Alexandrov topology

This file formalises the last three definitions of section 9.2 of the
AQFT-in-Lean blueprint: standard Minkowski spacetime, the Alexandrov
topology generated by intersections of chronological futures and pasts,
and Minkowski spacetime (= standard Minkowski equipped with the
Alexandrov topology).

## Main definitions

* `Physicslib4.StandardMinkowskiSpacetime`: the unique spacetime whose
  underlying manifold is `‚ĄĚ‚Āī` with its Euclidean topology and whose
  metric is `diag(-1, 1, 1, 1)` in the standard coordinates.
* `Physicslib4.Spacetime.alexandrovTopology`: the topology on a spacetime
  generated by all sets of the form `I^+(p) ‚ą© I^-(q)`.
* `Physicslib4.MinkowskiSpacetime`: a `Type` synonym for
  `StandardMinkowskiSpacetime.Carrier` carrying the Alexandrov topology
  as the canonical topology instance.

## Modelling notes

* The bilinear form on `T_p ‚ĄĚ‚Āī` corresponding to `diag(-1,1,1,1)` is
  constructed pointwise as a continuous bilinear map. We expose the
  underlying function on the model space; the proofs of symmetry,
  non-degeneracy, the Lorentzian condition, and smoothness in charts
  are left as `sorry`, since their formal expansion against Mathlib's
  `mfderiv` / `extChartAt` API for `‚ĄĚ‚Āī` is a substantial separate
  endeavour. The blueprint's *statement* is faithfully captured by the
  shape of `StandardMinkowskiSpacetime`.

* `MinkowskiSpacetime` is defined as a type synonym for the carrier of
  `StandardMinkowskiSpacetime` (i.e. `‚ĄĚ‚Āī`), with a `TopologicalSpace`
  instance given by the Alexandrov topology. The smooth-manifold
  structure is inherited from `StandardMinkowskiSpacetime` if one wishes
  to view the same underlying point set as both.
-/

namespace Physicslib4

open scoped Manifold

/-! ### Standard Minkowski spacetime -/

/-- The underlying bilinear `LinearMap` for the Minkowski metric on
`‚ĄĚ‚Āī`: `(v, w) ‚Ü¶ -v 0 * w 0 + v 1 * w 1 + v 2 * w 2 + v 3 * w 3`. -/
noncomputable def minkowskiForm‚āó :
    SpacetimeModel ‚Üí‚āó[‚ĄĚ] SpacetimeModel ‚Üí‚āó[‚ĄĚ] ‚ĄĚ :=
  LinearMap.mk‚āā ‚ĄĚ
    (fun v w => -(v 0) * (w 0) + (v 1) * (w 1) + (v 2) * (w 2) + (v 3) * (w 3))
    (fun v‚āĀ v‚āā w => by simp; ring)
    (fun c v w => by simp; ring)
    (fun v w‚āĀ w‚āā => by simp; ring)
    (fun c v w => by simp; ring)

/-- The Minkowski metric on `T_p ‚ĄĚ‚Āī = ‚ĄĚ‚Āī`, viewed as a continuous bilinear
form `‚ĄĚ‚Āī ‚ÜíL[‚ĄĚ] ‚ĄĚ‚Āī ‚ÜíL[‚ĄĚ] ‚ĄĚ` given by `(v, w) ‚Ü¶ -v 0 * w 0 + v 1 * w 1 +
v 2 * w 2 + v 3 * w 3`. This is the form whose Gram matrix in the standard
basis is `diag(-1, 1, 1, 1) = lorentzSignature`. -/
noncomputable def minkowskiForm :
    SpacetimeModel ‚ÜíL[‚ĄĚ] SpacetimeModel ‚ÜíL[‚ĄĚ] ‚ĄĚ :=
  LinearMap.toContinuousLinearMap
    { toFun := fun v => LinearMap.toContinuousLinearMap (minkowskiForm‚āó v)
      map_add' := fun v‚āĀ v‚āā => by
        ext w
        simp [minkowskiForm‚āó]
      map_smul' := fun c v => by
        ext w
        simp [minkowskiForm‚āó] }

@[simp] theorem minkowskiForm_apply (v w : SpacetimeModel) :
    minkowskiForm v w =
      -(v 0) * (w 0) + (v 1) * (w 1) + (v 2) * (w 2) + (v 3) * (w 3) := by
  rfl

/--
*Standard Minkowski spacetime* is the spacetime whose underlying real,
four-dimensional, connected, smooth, Hausdorff manifold is `‚ĄĚ‚Āī` (with the
Euclidean topology) and whose metric `g|_p` is `diag(-1, 1, 1, 1)` in the
standard coordinates, for every `p`.

We package the spacetime via the `Spacetime` structure, using the identity
charted space on `EuclideanSpace ‚ĄĚ (Fin 4)` and the identity model with
corners. The metric is the constant continuous bilinear form
`minkowskiForm`.
-/
noncomputable def StandardMinkowskiSpacetime : Spacetime where
  Carrier := SpacetimeModel
  topology := inferInstance
  hausdorff := inferInstance
  connected := inferInstance
  chartedSpace := chartedSpaceSelf SpacetimeModel
  model := modelWithCornersSelf ‚ĄĚ SpacetimeModel
  isManifold := by
    -- The identity charted space is a `C^‚ąě` manifold.
    infer_instance
  tangent_findim := fun _ => by
    -- `TangentSpace (modelWithCornersSelf ‚ĄĚ SpacetimeModel) _` reduces to
    -- `SpacetimeModel = EuclideanSpace ‚ĄĚ (Fin 4)`, which is finite-dimensional.
    change FiniteDimensional ‚ĄĚ SpacetimeModel
    infer_instance
  val := fun _ => minkowskiForm
  symm := by
    intro _ v w
    change minkowskiForm v w = minkowskiForm w v
    simp only [minkowskiForm_apply]
    ring
  nondegenerate := by
    intro _ v hv
    -- `TangentSpace ūĚďė(‚ĄĚ, SpacetimeModel) _` reduces to `SpacetimeModel`, so
    -- the hypothesis `hv` can be viewed at the model type for the `PiLp` API.
    have hv' : ‚ąÄ w : SpacetimeModel, minkowskiForm v w = 0 := hv
    apply PiLp.ext
    intro i
    -- The RHS `WithLp.ofLp 0 i` reduces definitionally to `(0 : ‚ĄĚ)`.
    change v.ofLp i = (0 : ‚ĄĚ)
    -- Instantiate `hv'` at the basis vector `EuclideanSpace.single i 1`.
    have hi := hv' (PiLp.single 2 i (1 : ‚ĄĚ))
    simp only [minkowskiForm_apply] at hi
    -- `(PiLp.single 2 i 1).ofLp j = if j = i then 1 else 0`. Splitting on
    -- `i : Fin 4` and simplifying collapses `hi` to `v.ofLp i = 0`.
    fin_cases i <;> simp_all
  lorentzian := by
    intro x
    -- Witness: the standard orthonormal basis of `EuclideanSpace ‚ĄĚ (Fin 4)`,
    -- viewed as a `Module.Basis` via `OrthonormalBasis.toBasis`.
    refine ‚ü®(EuclideanSpace.basisFun (Fin 4) ‚ĄĚ).toBasis, ?_‚ü©
    intro i j
    -- Unfold the lambda and the `TangentSpace`/`OrthonormalBasis.toBasis`
    -- machinery so the goal becomes about `minkowskiForm` on
    -- `EuclideanSpace.single _ 1` vectors.
    change minkowskiForm
        ((EuclideanSpace.basisFun (Fin 4) ‚ĄĚ) i)
        ((EuclideanSpace.basisFun (Fin 4) ‚ĄĚ) j) =
        lorentzSignature i j
    rw [EuclideanSpace.basisFun_apply, EuclideanSpace.basisFun_apply]
    simp only [minkowskiForm_apply, lorentzSignature, Matrix.diagonal]
    fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]
  smooth_in_charts := by
    intro x‚āÄ v w
    -- Unfold the `let e := extChartAt ... x‚āÄ` binding.
    simp only
    -- On the model space, `mfderiv I I (e.symm) y = id`, so the integrand is
    -- the constant `minkowskiForm v w` on `e.target = univ`.
    apply ContDiffWithinAt.congr_of_eventuallyEq
      (f := fun _ : SpacetimeModel => minkowskiForm v w)
    ¬∑ exact contDiffWithinAt_const
    ¬∑ -- Pointwise equality of the integrand with the constant `minkowskiForm v w`
      -- on a neighborhood of `e x‚āÄ` within `e.target`.
      filter_upwards with y
      have hsymm :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ).symm =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      rw [hsymm, mfderiv_id]
      rfl
    ¬∑ -- `(fun _ => minkowskiForm v w) (e x‚āÄ) = minkowskiForm v w`, and the
      -- function we replaced it with also evaluates to `minkowskiForm v w`
      -- at `y = e x‚āÄ` (since `e.symm (e x‚āÄ) = x‚āÄ` and `mfderiv id = id`).
      have hsymm :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ).symm =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      rw [hsymm, mfderiv_id]
      rfl

/-- Additive-group structure on the Minkowski spacetime carrier,
inherited from `SpacetimeModel = EuclideanSpace ‚ĄĚ (Fin 4)`. -/
noncomputable instance instAddCommGroupStandardMinkowskiCarrier :
    AddCommGroup StandardMinkowskiSpacetime.Carrier := by
  change AddCommGroup SpacetimeModel
  infer_instance

/-- `‚ĄĚ`-module structure on the Minkowski spacetime carrier,
inherited from `SpacetimeModel = EuclideanSpace ‚ĄĚ (Fin 4)`. -/
noncomputable instance instModuleStandardMinkowskiCarrier :
    Module ‚ĄĚ StandardMinkowskiSpacetime.Carrier := by
  change Module ‚ĄĚ SpacetimeModel
  infer_instance

/-! ### The orthochronous Lorentz group SO(1,3)‚ÜĎ -/

/-- A linear automorphism `L` of the spacetime model preserves the
Minkowski form: `‚ü®L v, L w‚ü© = ‚ü®v, w‚ü©` for all `v, w`. -/
def IsLorentz (L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel) : Prop :=
  ‚ąÄ v w, minkowskiForm (L v) (L w) = minkowskiForm v w

/-- A linear automorphism `L` is *proper* if its determinant is `1`. -/
def IsProper (L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel) : Prop :=
  LinearMap.det L.toLinearMap = 1

/-- A linear automorphism `L` is *orthochronous* if it preserves the
direction of time: the time component of `L e‚āÄ` is positive, where
`e‚āÄ = EuclideanSpace.single 0 1` is the standard timelike basis vector. -/
def IsOrthochronous (L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel) : Prop :=
  0 < (L (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ))) 0

/-- The identity preserves the Minkowski form. -/
theorem isLorentz_refl : IsLorentz (LinearEquiv.refl ‚ĄĚ SpacetimeModel) := by
  intro v w; rfl

/-- The composition of two Lorentz transformations is Lorentz. -/
theorem isLorentz_trans {L‚āĀ L‚āā : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (h‚āĀ : IsLorentz L‚āĀ) (h‚āā : IsLorentz L‚āā) : IsLorentz (L‚āĀ.trans L‚āā) := by
  intro v w
  simp only [LinearEquiv.trans_apply]
  rw [h‚āā, h‚āĀ]

/-- The inverse of a Lorentz transformation is Lorentz. -/
theorem isLorentz_symm {L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (h : IsLorentz L) : IsLorentz L.symm := by
  intro v w
  have := h (L.symm v) (L.symm w)
  rw [L.apply_symm_apply, L.apply_symm_apply] at this
  exact this.symm

/-- The identity is proper. -/
theorem isProper_refl : IsProper (LinearEquiv.refl ‚ĄĚ SpacetimeModel) := by
  unfold IsProper
  rw [LinearEquiv.refl_toLinearMap]
  exact LinearMap.det_id

/-- The composition of two proper transformations is proper. -/
theorem isProper_trans {L‚āĀ L‚āā : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (h‚āĀ : IsProper L‚āĀ) (h‚āā : IsProper L‚āā) : IsProper (L‚āĀ.trans L‚āā) := by
  unfold IsProper at h‚āĀ h‚āā ‚äĘ
  show LinearMap.det (L‚āĀ.trans L‚āā).toLinearMap = 1
  -- `(L‚āĀ.trans L‚āā).toLinearMap = L‚āā.toLinearMap ‚ąė‚āó L‚āĀ.toLinearMap`.
  have : (L‚āĀ.trans L‚āā).toLinearMap = L‚āā.toLinearMap ‚ąė‚āó L‚āĀ.toLinearMap := rfl
  rw [this, LinearMap.det_comp, h‚āĀ, h‚āā, mul_one]

/-- The inverse of a proper transformation is proper. -/
theorem isProper_symm {L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (h : IsProper L) : IsProper L.symm := by
  -- Use that `LinearEquiv.det` is a monoid hom to `Rň£` and
  -- `LinearEquiv.coe_inv_det` relates it to `LinearMap.det _.symm`.
  unfold IsProper at h ‚äĘ
  have h1 : (LinearEquiv.det L : ‚ĄĚ) = 1 := by
    rw [LinearEquiv.coe_det]; exact h
  -- `LinearMap.det L.symm = ‚ÜĎ(LinearEquiv.det L)‚ĀĽ¬Ļ`.
  rw [‚Üź LinearEquiv.coe_inv_det]
  -- `‚ÜĎ(u‚ĀĽ¬Ļ) = (‚ÜĎu)‚ĀĽ¬Ļ` for units, then use `h1`.
  rw [Units.val_inv_eq_inv_val, h1, inv_one]

/-- The identity is orthochronous. -/
theorem isOrthochronous_refl :
    IsOrthochronous (LinearEquiv.refl ‚ĄĚ SpacetimeModel) := by
  unfold IsOrthochronous
  simp only [LinearEquiv.refl_apply]
  -- `(EuclideanSpace.single 0 1) 0 = 1 > 0`.
  -- `EuclideanSpace ‚ĄĚ (Fin 4)` is definitionally `PiLp 2 (fun _ => ‚ĄĚ)`,
  -- and `(x : EuclideanSpace ‚ĄĚ őĻ) i = x.ofLp i` definitionally.
  change (0 : ‚ĄĚ) < (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0
  have : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0 = 1 := by
    rw [PiLp.single_apply]; simp
  rw [this]
  exact one_pos

/-- The composition of two orthochronous Lorentz transformations is
orthochronous. (Requires that both transformations are Lorentz.) -/
theorem isOrthochronous_trans {L‚āĀ L‚āā : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (hL‚āĀ : IsLorentz L‚āĀ) (hO‚āĀ : IsOrthochronous L‚āĀ)
    (hL‚āā : IsLorentz L‚āā) (hO‚āā : IsOrthochronous L‚āā) :
    IsOrthochronous (L‚āĀ.trans L‚āā) := by
  -- TODO: requires reverse Cauchy-Schwarz on a Lorentzian form
  sorry

/-- The inverse of an orthochronous Lorentz transformation is
orthochronous. -/
theorem isOrthochronous_symm {L : SpacetimeModel ‚ČÉ‚āó[‚ĄĚ] SpacetimeModel}
    (hL : IsLorentz L) (hO : IsOrthochronous L) : IsOrthochronous L.symm := by
  -- TODO: requires reverse Cauchy-Schwarz on a Lorentzian form
  sorry

/-! ### Alexandrov topology -/

namespace Spacetime

variable (M : Spacetime)

attribute [instance] Spacetime.topology Spacetime.hausdorff Spacetime.connected
  Spacetime.chartedSpace Spacetime.isManifold Spacetime.tangent_findim

/-- The basis sets generating the Alexandrov topology: all sets of the
form `I^+(p) ‚ą© I^-(q)` for `p, q ‚ąą M`. -/
def alexandrovBasis (t : M.TimeOrientation) : Set (Set M.Carrier) :=
  {U | ‚ąÉ p q : M.Carrier, U = chronologicalFuture M t p ‚ą© chronologicalPast M t q}

/--
The *Alexandrov topology* on a spacetime `M`, with respect to a chosen
time orientation `t`: the topology generated by the basis `alexandrovBasis`
consisting of all intersections of chronological futures and pasts.
-/
@[reducible] def alexandrovTopology (t : M.TimeOrientation) :
    TopologicalSpace M.Carrier :=
  TopologicalSpace.generateFrom (alexandrovBasis M t)

end Spacetime

/-! ### The forward and backward Minkowski-cones -/

/-- The *forward Minkowski-cone* of a point `p ‚ąą ‚ĄĚ‚Āī`: the set of
points `q` with `p.0 < q.0` and `-(q.0 - p.0)¬≤ + ő£_{i>0} (q.i - p.i)¬≤ < 0`.
This is the coordinate-explicit form of the chronological future of `p`
on standard Minkowski spacetime. -/
def minkowskiForwardCone (p : SpacetimeModel) : Set SpacetimeModel :=
  {q | p 0 < q 0 ‚ąß
    -(q 0 - p 0)^2 + (q 1 - p 1)^2 + (q 2 - p 2)^2 + (q 3 - p 3)^2 < 0}

/-- The *backward Minkowski-cone* of a point `q ‚ąą ‚ĄĚ‚Āī`: the set of points
`p` with `p.0 < q.0` and `-(q.0 - p.0)¬≤ + ő£_{i>0} (q.i - p.i)¬≤ < 0`.
Equivalently, `p ‚ąą minkowskiBackwardCone q ‚ÜĒ q ‚ąą minkowskiForwardCone p`. -/
def minkowskiBackwardCone (q : SpacetimeModel) : Set SpacetimeModel :=
  {p | p 0 < q 0 ‚ąß
    -(q 0 - p 0)^2 + (q 1 - p 1)^2 + (q 2 - p 2)^2 + (q 3 - p 3)^2 < 0}

@[simp] theorem mem_minkowskiForwardCone (p q : SpacetimeModel) :
    q ‚ąą minkowskiForwardCone p ‚ÜĒ
      p 0 < q 0 ‚ąß
      -(q 0 - p 0)^2 + (q 1 - p 1)^2 + (q 2 - p 2)^2 + (q 3 - p 3)^2 < 0 := Iff.rfl

@[simp] theorem mem_minkowskiBackwardCone (p q : SpacetimeModel) :
    p ‚ąą minkowskiBackwardCone q ‚ÜĒ
      p 0 < q 0 ‚ąß
      -(q 0 - p 0)^2 + (q 1 - p 1)^2 + (q 2 - p 2)^2 + (q 3 - p 3)^2 < 0 := Iff.rfl

theorem minkowskiBackwardCone_eq (q : SpacetimeModel) :
    minkowskiBackwardCone q = {p | q ‚ąą minkowskiForwardCone p} := rfl

/-! ### Minkowski spacetime -/

/--
*Minkowski spacetime* is the carrier of `StandardMinkowskiSpacetime`
viewed as a topological space under the Alexandrov topology.

We expose `MinkowskiSpacetime` as a `def` returning a `Spacetime`,
following the convention used for `StandardMinkowskiSpacetime`. The
"underlying topology is the Alexandrov topology" character of Minkowski
spacetime is captured at the typeclass level by the alternative
`MinkowskiSpacetimeCarrier` synonym below, which carries the Alexandrov
topology directly.

A time orientation `t` on standard Minkowski spacetime is required to
talk about the Alexandrov topology. We leave its construction as
`sorry`; the canonical choice is the constant timelike vector field
`‚ąā_0` pointing in the `0`-th coordinate direction.
-/
noncomputable def standardMinkowskiTimeOrientation :
    StandardMinkowskiSpacetime.TimeOrientation where
  field := fun _ => EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)
  nonvanishing := by
    intro x h
    have h0 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0 = 1 := by
      rw [PiLp.single_apply]; simp
    have hzero : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0 =
        (0 : SpacetimeModel).ofLp 0 := by rw [h]; rfl
    have hz : (0 : SpacetimeModel).ofLp 0 = (0 : ‚ĄĚ) := rfl
    rw [h0, hz] at hzero
    exact one_ne_zero hzero
  timelike_at := by
    intro x
    change minkowskiForm (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ))
                         (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)) < 0
    simp only [minkowskiForm_apply]
    have h0 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0 = 1 := by
      rw [PiLp.single_apply]; simp
    have h1 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 1 = 0 := by
      rw [PiLp.single_apply]; simp
    have h2 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 2 = 0 := by
      rw [PiLp.single_apply]; simp
    have h3 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 3 = 0 := by
      rw [PiLp.single_apply]; simp
    change -((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0) *
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0) +
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 1) *
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 1) +
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 2) *
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 2) +
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 3) *
        ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 3) < 0
    rw [h0, h1, h2, h3]
    norm_num
  smooth := by
    intro x‚āÄ
    -- `StandardMinkowskiSpacetime.Carrier = SpacetimeModel` by `rfl`. Cast
    -- `x‚āÄ` to `SpacetimeModel` explicitly so the structure projections in
    -- the goal reduce, matching the pattern of `smooth_in_charts`.
    let x‚āÄ' : SpacetimeModel := x‚āÄ
    change ContDiffWithinAt ‚ĄĚ ‚ä§
      (fun y => mfderiv (modelWithCornersSelf ‚ĄĚ SpacetimeModel)
                        (modelWithCornersSelf ‚ĄĚ SpacetimeModel)
          (extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ').symm y
          (mfderiv (modelWithCornersSelf ‚ĄĚ SpacetimeModel)
                   (modelWithCornersSelf ‚ĄĚ SpacetimeModel)
            (extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ')
            ((extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ').symm y)
            (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ))))
      (extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ').target
      ((extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ') x‚āÄ')
    apply ContDiffWithinAt.congr_of_eventuallyEq
      (f := fun _ : SpacetimeModel => EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ))
    ¬∑ exact contDiffWithinAt_const
    ¬∑ filter_upwards with y
      have hsymm :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ').symm =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      have hchart :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ') =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      rw [hsymm, hchart]
      simp only [mfderiv_id]
      rfl
    ¬∑ have hsymm :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ').symm =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      have hchart :
          ‚áĎ(extChartAt (modelWithCornersSelf ‚ĄĚ SpacetimeModel) x‚āÄ') =
            (id : SpacetimeModel ‚Üí SpacetimeModel) := by
        simp
      rw [hsymm, hchart]
      simp only [mfderiv_id]
      rfl

/-!
### Characterisation of the chronological future on standard Minkowski

The two theorems below identify `chronologicalFuture` and
`chronologicalPast` on `StandardMinkowskiSpacetime` (with the canonical
time orientation `‚ąā_0`) with the coordinate-explicit forward / backward
Minkowski-cones. Both statements are needed downstream to compare the
Alexandrov topology with the Euclidean topology on `‚ĄĚ‚Āī`; both are left
as `sorry` here. The intended proof strategy is as follows.

* **Forward direction** (`chronologicalFuture ‚äÜ minkowskiForwardCone`):
  given a chronological trip from `p` to `q`, one has a smooth curve
  `őľ : [a, b] ‚Üí ‚ĄĚ‚Āī` whose tangent `őľ'(s)` is everywhere timelike
  (`g(őľ'(s), őľ'(s)) < 0`) and future-oriented
  (`g(‚ąā_0, őľ'(s)) < 0`). Integrating `őľ'` over `[a, b]` yields
  `q - p = ‚ąę_a^b őľ'(s) ds`. The open forward time-cone in `‚ĄĚ‚Āī` is a
  convex cone (closed under positive-linear combinations of timelike
  future-oriented vectors), so `q - p` lies in the open forward cone,
  i.e. `(q - p) 0 > 0` and `-((q - p) 0)^2 + ő£_{i>0} ((q - p) i)^2 < 0`.
* **Reverse direction** (`minkowskiForwardCone ‚äÜ chronologicalFuture`):
  given `q ‚ąą minkowskiForwardCone p`, define the straight-line path
  `őľ : [0, 1] ‚Üí ‚ĄĚ‚Āī`, `s ‚Ü¶ p + s ‚ÄĘ (q - p)`. Then `őľ` is linear, hence
  `C^‚ąě`; its derivative is the constant vector `q - p`, which is
  nonvanishing (since `p 0 < q 0` forces `q ‚Č† p`), timelike (the
  Minkowski form of `q - p` with itself is the hypothesis), and
  future-oriented (since `(q - p) 0 > 0`). The geodesic flag
  `IsGeodesic = True` is automatic for the chosen API, and the endpoint
  conditions are witnessed by `0`, `1 ‚ąą frontier (Set.Icc 0 1) = {0, 1}`
  together with `őľ 0 = p` and `őľ 1 = q`.

Both directions ultimately appeal to the smooth-curve API in
`Physicslib4.Spacetime.Curves` and the chronological-trip definition in
`Physicslib4.Spacetime.Causality`. The reverse direction has been
scaffolded structurally as
`minkowskiForwardCone_subset_chronologicalFuture_standardMinkowski`,
with the analytic content factored into the named lemmas
`standardMinkowski_lineSegmentPath_continuousOn`,
`standardMinkowski_lineSegmentPath_smoothOn`,
`standardMinkowski_lineSegmentPath_mfderivWithin` and
`standardMinkowski_lineSegmentPath_nonvanishing`, each currently
`sorry`'d. The forward direction is bundled as
`chronologicalFuture_standardMinkowski_subset` and still `sorry`'d
pending the integration argument.
-/

/-- The straight-line path `s ‚Ü¶ p + s ‚ÄĘ (q - p)` is continuous on `[0, 1]`.
*(Analytic stub for the chronological-future characterisation: easy from
`continuousOn_const` / `Continuous.smul` / `continuousOn_id` but written as
a stub here to keep this first pass structural.)* -/
theorem standardMinkowski_lineSegmentPath_continuousOn (p q : SpacetimeModel) :
    ContinuousOn (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
      (Set.Icc (0 : ‚ĄĚ) 1) :=
  (continuous_const.add (Continuous.smul continuous_id continuous_const)).continuousOn

/-- The straight-line path `s ‚Ü¶ p + s ‚ÄĘ (q - p)` is `C^‚ąě` on `[0, 1]`,
viewed as a map from `(‚ĄĚ, modelWithCornersSelf ‚ĄĚ ‚ĄĚ)` to standard Minkowski
spacetime. *(Analytic stub for the chronological-future characterisation.)* -/
theorem standardMinkowski_lineSegmentPath_smoothOn (p q : SpacetimeModel) :
    ContMDiffOn (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
      StandardMinkowskiSpacetime.model ‚ä§
      (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
      (Set.Icc (0 : ‚ĄĚ) 1) := by
  have h : ContDiff ‚ĄĚ (‚ä§ : WithTop ‚Ąē‚ąě) (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p)) :=
    contDiff_const.add (contDiff_id.smul contDiff_const)
  exact (contMDiff_iff_contDiff.mpr h).contMDiffOn

/-- The derivative of the straight-line path `s ‚Ü¶ p + s ‚ÄĘ (q - p)` at every
point of `[0, 1]`, applied to the basis vector `1 : ‚ĄĚ`, equals `q - p`.
*(Analytic stub for the chronological-future characterisation.)* -/
theorem standardMinkowski_lineSegmentPath_mfderivWithin (p q : SpacetimeModel) :
    ‚ąÄ s ‚ąą Set.Icc (0 : ‚ĄĚ) 1,
      mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
        StandardMinkowskiSpacetime.model
        (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
        (Set.Icc 0 1) s (1 : ‚ĄĚ) = q - p := by
  sorry

/-- The straight-line path `s ‚Ü¶ p + s ‚ÄĘ (q - p)` has non-vanishing derivative
`q - p` (assuming `p ‚Č† q`). *(Analytic stub for the chronological-future
characterisation: follows from `standardMinkowski_lineSegmentPath_mfderivWithin`
together with `p ‚Č† q`.)* -/
theorem standardMinkowski_lineSegmentPath_nonvanishing (p q : SpacetimeModel)
    (hpq : p ‚Č† q) :
    ‚ąÄ s ‚ąą Set.Icc (0 : ‚ĄĚ) 1,
      mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
        StandardMinkowskiSpacetime.model
        (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
        (Set.Icc 0 1) s (1 : ‚ĄĚ) ‚Č† 0 := by
  intro s hs
  rw [standardMinkowski_lineSegmentPath_mfderivWithin p q s hs]
  intro hzero
  apply hpq
  have hqp : q = p := sub_eq_zero.mp hzero
  exact hqp.symm

/-- The straight-line `SmoothPath` from `p` to `q` on standard Minkowski
spacetime: `s ‚Ü¶ p + s ‚ÄĘ (q - p)` parametrised by `[0, 1]`. This is the
canonical witness for the reverse direction of
`chronologicalFuture_standardMinkowski`. -/
noncomputable def standardMinkowski_lineSegmentPath
    (p q : SpacetimeModel) (hpq : p ‚Č† q) :
    StandardMinkowskiSpacetime.SmoothPath where
  parameterSpace := Set.Icc (0 : ‚ĄĚ) 1
  isClosed := isClosed_Icc
  isConnected := ‚ü®‚ü®0, by simp‚ü©, isPreconnected_Icc‚ü©
  nontrivial := ‚ü®0, 1, by simp, by simp, zero_ne_one‚ü©
  toFun := fun s => (p : SpacetimeModel) + s ‚ÄĘ (q - p)
  continuousOn := standardMinkowski_lineSegmentPath_continuousOn p q
  smoothOn := standardMinkowski_lineSegmentPath_smoothOn p q
  nonvanishing := standardMinkowski_lineSegmentPath_nonvanishing p q hpq

/-- *Forward subset* of `chronologicalFuture_standardMinkowski`: every
point in the chronological future of `p` lies in the open forward
Minkowski-cone. This direction requires integrating the timelike
tangent vector over a trip, and is currently `sorry`'d. -/
theorem chronologicalFuture_standardMinkowski_subset (p : SpacetimeModel) :
    Spacetime.chronologicalFuture StandardMinkowskiSpacetime
        standardMinkowskiTimeOrientation p
      ‚äÜ minkowskiForwardCone p := by
  sorry

/-- *Reverse subset* of `chronologicalFuture_standardMinkowski`: every
point of the open forward Minkowski-cone of `p` lies in the chronological
future of `p`. Witnessed by the straight-line path
`standardMinkowski_lineSegmentPath`. -/
theorem minkowskiForwardCone_subset_chronologicalFuture_standardMinkowski
    (p : SpacetimeModel) :
    minkowskiForwardCone p ‚äÜ
      Spacetime.chronologicalFuture StandardMinkowskiSpacetime
        standardMinkowskiTimeOrientation p := by
  intro q hq
  obtain ‚ü®h_time, h_cone‚ü© := hq
  have hpq : p ‚Č† q := by
    intro h
    rw [h] at h_time
    exact lt_irrefl _ h_time
  refine ‚ü®Spacetime.SmoothCurve.ofPath _
    (standardMinkowski_lineSegmentPath p q hpq), ?_‚ü©
  refine ‚ü®standardMinkowski_lineSegmentPath p q hpq, rfl, ?_, ?_, ?_, ?_, ?_‚ü©
  ¬∑ intro s hs
    have hs' : s ‚ąą Set.Icc (0 : ‚ĄĚ) 1 := hs
    change minkowskiForm
        (mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
          StandardMinkowskiSpacetime.model
          (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
          (Set.Icc 0 1) s (1 : ‚ĄĚ))
        (mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
          StandardMinkowskiSpacetime.model
          (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
          (Set.Icc 0 1) s (1 : ‚ĄĚ)) < 0
    rw [standardMinkowski_lineSegmentPath_mfderivWithin p q s hs']
    simp only [minkowskiForm_apply]
    have e0 : (q - p) 0 = q 0 - p 0 := rfl
    have e1 : (q - p) 1 = q 1 - p 1 := rfl
    have e2 : (q - p) 2 = q 2 - p 2 := rfl
    have e3 : (q - p) 3 = q 3 - p 3 := rfl
    rw [e0, e1, e2, e3]
    have hcone : -(q 0 - p 0) ^ 2 + (q 1 - p 1) ^ 2 +
        (q 2 - p 2) ^ 2 + (q 3 - p 3) ^ 2 < 0 := h_cone
    nlinarith [hcone, sq_nonneg (q 0 - p 0), sq_nonneg (q 1 - p 1),
               sq_nonneg (q 2 - p 2), sq_nonneg (q 3 - p 3)]
  ¬∑ intro s hs
    have hs' : s ‚ąą Set.Icc (0 : ‚ĄĚ) 1 := hs
    left
    refine ‚ü®?_, ?_‚ü©
    ¬∑ change minkowskiForm
          (mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
            StandardMinkowskiSpacetime.model
            (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
            (Set.Icc 0 1) s (1 : ‚ĄĚ))
          (mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
            StandardMinkowskiSpacetime.model
            (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
            (Set.Icc 0 1) s (1 : ‚ĄĚ)) < 0
      rw [standardMinkowski_lineSegmentPath_mfderivWithin p q s hs']
      simp only [minkowskiForm_apply]
      have e0 : (q - p) 0 = q 0 - p 0 := rfl
      have e1 : (q - p) 1 = q 1 - p 1 := rfl
      have e2 : (q - p) 2 = q 2 - p 2 := rfl
      have e3 : (q - p) 3 = q 3 - p 3 := rfl
      rw [e0, e1, e2, e3]
      have hcone : -(q 0 - p 0) ^ 2 + (q 1 - p 1) ^ 2 +
          (q 2 - p 2) ^ 2 + (q 3 - p 3) ^ 2 < 0 := h_cone
      nlinarith [hcone, sq_nonneg (q 0 - p 0), sq_nonneg (q 1 - p 1),
                 sq_nonneg (q 2 - p 2), sq_nonneg (q 3 - p 3)]
    ¬∑ change minkowskiForm (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ))
          (mfderivWithin (modelWithCornersSelf ‚ĄĚ ‚ĄĚ)
            StandardMinkowskiSpacetime.model
            (fun s : ‚ĄĚ => (p : SpacetimeModel) + s ‚ÄĘ (q - p))
            (Set.Icc 0 1) s (1 : ‚ĄĚ)) < 0
      rw [standardMinkowski_lineSegmentPath_mfderivWithin p q s hs']
      simp only [minkowskiForm_apply]
      have h0 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0 = 1 := by
        rw [PiLp.single_apply]; simp
      have h1 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 1 = 0 := by
        rw [PiLp.single_apply]; simp
      have h2 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 2 = 0 := by
        rw [PiLp.single_apply]; simp
      have h3 : (EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 3 = 0 := by
        rw [PiLp.single_apply]; simp
      change -((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 0)
          * ((q - p).ofLp 0) +
          ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 1) *
          ((q - p).ofLp 1) +
          ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 2) *
          ((q - p).ofLp 2) +
          ((EuclideanSpace.single (0 : Fin 4) (1 : ‚ĄĚ)).ofLp 3) *
          ((q - p).ofLp 3) < 0
      rw [h0, h1, h2, h3]
      have e0' : (q - p).ofLp 0 = q 0 - p 0 := rfl
      rw [e0']
      linarith
  ¬∑ trivial
  ¬∑ refine ‚ü®0, ?_, ?_, ?_‚ü©
    ¬∑ change (0 : ‚ĄĚ) ‚ąą frontier (Set.Icc (0 : ‚ĄĚ) 1)
      rw [frontier_Icc (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)]
      left; rfl
    ¬∑ change (p : SpacetimeModel) + (0 : ‚ĄĚ) ‚ÄĘ (q - p) = p
      simp
    ¬∑ intro s' hs'
      have hs'' : s' ‚ąą frontier (Set.Icc (0 : ‚ĄĚ) 1) := hs'
      rw [frontier_Icc (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)] at hs''
      rcases hs'' with h | h
      ¬∑ exact h.ge
      ¬∑ rw [Set.mem_singleton_iff] at h
        rw [h]; norm_num
  ¬∑ refine ‚ü®1, ?_, ?_, ?_‚ü©
    ¬∑ change (1 : ‚ĄĚ) ‚ąą frontier (Set.Icc (0 : ‚ĄĚ) 1)
      rw [frontier_Icc (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)]
      right; rfl
    ¬∑ change (p : SpacetimeModel) + (1 : ‚ĄĚ) ‚ÄĘ (q - p) = q
      simp
    ¬∑ intro s' hs'
      have hs'' : s' ‚ąą frontier (Set.Icc (0 : ‚ĄĚ) 1) := hs'
      rw [frontier_Icc (by norm_num : (0 : ‚ĄĚ) ‚Č§ 1)] at hs''
      rcases hs'' with h | h
      ¬∑ rw [h]; norm_num
      ¬∑ rw [Set.mem_singleton_iff] at h
        exact h.le

/-- **Characterisation of `chronologicalFuture` on standard Minkowski.**
The chronological future of `p` on `StandardMinkowskiSpacetime` agrees with
the forward Minkowski-cone of `p`. This is the coordinate-explicit form of
`I‚Āļ(p)` that lets the agreement of the Alexandrov topology with the
Euclidean topology on `‚ĄĚ‚Āī` be proved. The two directions are split into
`chronologicalFuture_standardMinkowski_subset` (still `sorry`) and
`minkowskiForwardCone_subset_chronologicalFuture_standardMinkowski`
(scaffolded with small analytic stubs). -/
theorem chronologicalFuture_standardMinkowski (p : SpacetimeModel) :
    Spacetime.chronologicalFuture StandardMinkowskiSpacetime
        standardMinkowskiTimeOrientation p
      = minkowskiForwardCone p :=
  Set.Subset.antisymm
    (chronologicalFuture_standardMinkowski_subset p)
    (minkowskiForwardCone_subset_chronologicalFuture_standardMinkowski p)

/-- **Characterisation of `chronologicalPast` on standard Minkowski.**
Dual to `chronologicalFuture_standardMinkowski`, obtained from it by the
definitional time-reversal symmetry of `ChronologicallyPrecedes`. -/
theorem chronologicalPast_standardMinkowski (q : SpacetimeModel) :
    Spacetime.chronologicalPast StandardMinkowskiSpacetime
        standardMinkowskiTimeOrientation q
      = minkowskiBackwardCone q := by
  ext p
  change p ‚ąą Spacetime.chronologicalPast StandardMinkowskiSpacetime
                 standardMinkowskiTimeOrientation q
       ‚ÜĒ p ‚ąą minkowskiBackwardCone q
  rw [show p ‚ąą Spacetime.chronologicalPast StandardMinkowskiSpacetime
              standardMinkowskiTimeOrientation q
        ‚ÜĒ q ‚ąą Spacetime.chronologicalFuture StandardMinkowskiSpacetime
              standardMinkowskiTimeOrientation p
        from Iff.rfl,
      chronologicalFuture_standardMinkowski p,
      minkowskiBackwardCone_eq]
  rfl

/-- A `Type` synonym for the carrier of standard Minkowski spacetime
intended to carry the Alexandrov topology. -/
def MinkowskiSpacetimeCarrier : Type := StandardMinkowskiSpacetime.Carrier

/-- The Alexandrov topology on `MinkowskiSpacetimeCarrier`. -/
noncomputable instance : TopologicalSpace MinkowskiSpacetimeCarrier :=
  Spacetime.alexandrovTopology StandardMinkowskiSpacetime
    standardMinkowskiTimeOrientation

/--
*Minkowski spacetime* is standard Minkowski spacetime re-topologised with
the Alexandrov topology generated by intersections of chronological
futures and pasts.

We return a `Spacetime` whose carrier is `MinkowskiSpacetimeCarrier`,
whose smooth-manifold data is inherited from `StandardMinkowskiSpacetime`,
and whose metric is `minkowskiForm`. The retopologisation of the carrier
to the Alexandrov topology is handled by the `TopologicalSpace` instance
on `MinkowskiSpacetimeCarrier`; the remaining smooth-manifold data is
re-asserted as `sorry`, since proving that the smooth-manifold structure
on `StandardMinkowskiSpacetime` transports to the Alexandrov topology is
mathematically non-trivial (it is the *content* of section 2.4 of the
blueprint).
-/
noncomputable def MinkowskiSpacetime : Spacetime where
  Carrier := MinkowskiSpacetimeCarrier
  topology := inferInstance
  hausdorff := by sorry
  connected := by sorry
  chartedSpace := by
    -- Carry over the chart structure from `StandardMinkowskiSpacetime` via
    -- the identity on points.
    sorry
  model := StandardMinkowskiSpacetime.model
  isManifold := by sorry
  tangent_findim := fun _ => by
    -- `TangentSpace (modelWithCornersSelf ‚ĄĚ SpacetimeModel) _` reduces to
    -- `SpacetimeModel = EuclideanSpace ‚ĄĚ (Fin 4)`, which is finite-dimensional.
    change FiniteDimensional ‚ĄĚ SpacetimeModel
    infer_instance
  val := fun _ => minkowskiForm
  symm := by
    intro _ v w
    change minkowskiForm v w = minkowskiForm w v
    simp only [minkowskiForm_apply]
    ring
  nondegenerate := by
    intro _ v hv
    -- `TangentSpace ūĚďė(‚ĄĚ, SpacetimeModel) _` reduces to `SpacetimeModel`, so
    -- the hypothesis `hv` can be viewed at the model type for the `PiLp` API.
    have hv' : ‚ąÄ w : SpacetimeModel, minkowskiForm v w = 0 := hv
    apply PiLp.ext
    intro i
    -- The RHS `WithLp.ofLp 0 i` reduces definitionally to `(0 : ‚ĄĚ)`.
    change v.ofLp i = (0 : ‚ĄĚ)
    -- Instantiate `hv'` at the basis vector `EuclideanSpace.single i 1`.
    have hi := hv' (PiLp.single 2 i (1 : ‚ĄĚ))
    simp only [minkowskiForm_apply] at hi
    -- `(PiLp.single 2 i 1).ofLp j = if j = i then 1 else 0`. Splitting on
    -- `i : Fin 4` and simplifying collapses `hi` to `v.ofLp i = 0`.
    fin_cases i <;> simp_all
  lorentzian := by
    intro x
    -- Witness: the standard orthonormal basis of `EuclideanSpace ‚ĄĚ (Fin 4)`,
    -- viewed as a `Module.Basis` via `OrthonormalBasis.toBasis`.
    refine ‚ü®(EuclideanSpace.basisFun (Fin 4) ‚ĄĚ).toBasis, ?_‚ü©
    intro i j
    -- Unfold the lambda and the `TangentSpace`/`OrthonormalBasis.toBasis`
    -- machinery so the goal becomes about `minkowskiForm` on
    -- `EuclideanSpace.single _ 1` vectors.
    change minkowskiForm
        ((EuclideanSpace.basisFun (Fin 4) ‚ĄĚ) i)
        ((EuclideanSpace.basisFun (Fin 4) ‚ĄĚ) j) =
        lorentzSignature i j
    rw [EuclideanSpace.basisFun_apply, EuclideanSpace.basisFun_apply]
    simp only [minkowskiForm_apply, lorentzSignature, Matrix.diagonal]
    fin_cases i <;> fin_cases j <;> simp [Matrix.of_apply]
  smooth_in_charts := by sorry

